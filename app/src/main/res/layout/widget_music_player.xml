<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@drawable/widget_background">

    <!-- Album art placeholder -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:contentDescription="Album Art" />

    <!-- Track info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CIPHER Music"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No track playing"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Controls -->
    <ImageButton
        android:id="@+id/widget_prev"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_prev_widget"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Previous"
        android:scaleType="centerInside" />

    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_play_widget"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Play/Pause"
        android:scaleType="centerInside"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_next_widget"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Next"
        android:scaleType="centerInside" />

</LinearLayout>
